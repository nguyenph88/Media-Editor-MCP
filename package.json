{
  "name": "media-editor-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo of MCP servers for video editors (CapCut, Premiere Pro) + a shared media-analysis server",
  "workspaces": [
    "packages/premiere-protocol",
    "packages/premiere-server",
    "packages/premiere-uxp-plugin"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:server": "npm run build -w @ppmcp/server",
    "build:plugin": "npm run build -w @ppmcp/uxp-plugin",
    "dev:server": "npm run dev -w @ppmcp/server",
    "watch:plugin": "npm run watch -w @ppmcp/uxp-plugin"
  },
  "engines": {
    "node": ">=20"
  }
}
