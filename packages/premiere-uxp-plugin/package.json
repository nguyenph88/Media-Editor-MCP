{
  "name": "@ppmcp/uxp-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=cjs --target=es2020 --external:uxp --external:premierepro --alias:@ppmcp/protocol=./../premiere-protocol/src/index.ts --outfile=dist/main.js",
    "watch": "esbuild src/main.ts --bundle --format=cjs --target=es2020 --external:uxp --external:premierepro --alias:@ppmcp/protocol=./../premiere-protocol/src/index.ts --outfile=dist/main.js --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@ppmcp/protocol": "*",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
